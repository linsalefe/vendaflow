# ─── DATABASE ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vendaflow:senha@localhost:5432/vendaflow_db

# ─── FRONTEND ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── OPENAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── EVOLUTION API (WhatsApp) ──────────────────────────────────────────
EVOLUTION_API_URL=https://evo.seudominio.com
EVOLUTION_API_KEY=sua-api-key

# ─── STRIPE (configurável por tenant, mas pode ter default) ───────────
# As chaves Stripe são por tenant no banco de dados
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=sua-chave-secreta-jwt
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
